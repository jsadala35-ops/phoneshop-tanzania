# Application Configuration
NEXT_PUBLIC_APP_NAME=PhoneShop Pro Edition
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_TIMEZONE=Africa/Dar_es_Salaam
NODE_ENV=development

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000/api
API_TIMEOUT=30000

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/phoneshop_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=phoneshop_db
DB_USER=phoneshop_user
DB_PASSWORD=your_secure_password

# Authentication
JWT_SECRET=your_jwt_secret_key_min_32_characters_long
JWT_EXPIRE=7d
REFRESH_TOKEN_SECRET=your_refresh_token_secret
SESSION_SECRET=your_session_secret

# Admin Credentials
ADMIN_EMAIL=jsadala35@gmail.com
ADMIN_PHONE=0673409790

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# File Upload
UPLOAD_DIR=./public/uploads
MAX_FILE_SIZE=10485760

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Security
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT=100

# Feature Flags
FEATURE_REPORTS=true
FEATURE_ANALYTICS=true
FEATURE_CUSTOMER_LOYALTY=false
FEATURE_PAYMENT_INTEGRATION=false

# Third-party Services
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
